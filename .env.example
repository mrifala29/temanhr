# Backend Configuration
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000/api

# Database (Supabase)
DATABASE_URL=postgresql://user:password@host:5432/temanhr

# JWT
JWT_SECRET=your-256-bit-secret-key-here-minimum-32-characters

# File Upload
STORAGE_PATH=/var/app/storage
MAX_ZIP_SIZE_MB=50
MAX_PDF_SIZE_MB=10

# Frontend
FRONTEND_URL=http://localhost:5173

# AI Service
AI_API_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4
MAX_RETRIES=3
CONCURRENCY_LIMIT=5

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/temanhr/app.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=100
